{
	"appId": "com.delivery.one",
	"appName": "Delivery One",
	"webDir": "dist/public",
	"server": {
		"androidScheme": "https",
		"cleartext": false
	},
	"android": {
		"allowMixedContent": false
	},
	"plugins": {
		"SplashScreen": {
			"launchShowDuration": 3000,
			"launchAutoHide": true,
			"showSpinner": true,
			"spinnerColor": "white"
		},
		"CapacitorHttp": {
			"enabled": true
		}
	}
}
